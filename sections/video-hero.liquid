<style>
  .video-hero {
    position: relative;
    width: 100%;
    margin: 0;
    overflow: hidden;
    height: 80vh;
  }

  .video-hero__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    background: #0a0a0a;
  }

  .video-hero__media video,
  .video-hero__media iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    transform: scale(1.05); /* hide iframe borders */
  }

  .video-hero::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.6) 100%);
    z-index: 2;
    pointer-events: none;
  }

  .video-hero__content-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 4rem 2rem;
  }

  .video-hero__content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .video-hero__heading {
    color: #ffffff;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
    text-shadow: 0 4px 15px rgba(0,0,0,0.5);
  }

  .video-hero .button {
    background: transparent;
    color: #ffffff;
    border: 1px solid #ffffff;
  }
  .video-hero .button:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-button-text);
  }
</style>

<div class="video-hero">
  <div class="video-hero__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '1200x' }}
    {%- elsif section.settings.video_url != blank -%}
      {%- if section.settings.video_url.type == 'youtube' -%}
        <iframe src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=1&mute=1&loop=1&controls=0&showinfo=0&rel=0&playlist={{ section.settings.video_url.id }}&modestbranding=1" frameborder="0" allowfullscreen></iframe>
      {%- elsif section.settings.video_url.type == 'vimeo' -%}
        <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?background=1&autoplay=1&loop=1&byline=0&title=0" frameborder="0" allowfullscreen></iframe>
      {%- endif -%}
    {%- else -%}
      <!-- Default fallback video for premium watch (Rolex Submariner) -->
      <iframe src="https://www.youtube.com/embed/kY2n5b4zVw0?autoplay=1&mute=1&loop=1&controls=0&showinfo=0&rel=0&playlist=kY2n5b4zVw0&modestbranding=1" frameborder="0" allowfullscreen></iframe>
    {%- endif -%}
  </div>

  <div class="video-hero__content-wrapper">
    <div class="video-hero__content reveal">
      {%- if section.settings.heading != blank -%}
        <h2 class="video-hero__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="button">{{ section.settings.button_label | escape }}</a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Video Hero",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Shopify-hosted video",
      "info": "Upload an MP4 video for best performance and looping."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "default": "https://www.youtube.com/watch?v=ScMzIvxBSi4",
      "label": "URL fallback video",
      "info": "Used if no Shopify video is selected."
    },
    {
      "type": "text",
      "id": "heading",
      "default": "The Art of Time",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Discover",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Video Hero"
    }
  ]
}
{% endschema %}
