<style>
  .announcement-bar {
    background-color: var(--color-foreground);
    color: var(--color-background);
    overflow: hidden;
    padding: 0;
    height: 2.5rem;
    display: flex;
    align-items: center;
  }

  .announcement-bar__marquee {
    display: flex;
    width: 100%;
    overflow: hidden;
  }

  .announcement-bar__track {
    display: flex;
    gap: 0;
    animation: marquee-scroll 30s linear infinite;
    white-space: nowrap;
  }

  .announcement-bar__track:hover {
    animation-play-state: paused;
  }

  .announcement-bar__item {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0 2.5rem;
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .announcement-bar__item a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .announcement-bar__item a:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .announcement-bar__sep {
    color: var(--color-accent);
    font-size: 0.6rem;
  }

  @keyframes marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

{%- if section.settings.show_announcement -%}
<div class="announcement-bar" role="marquee" aria-label="Announcements">
  <div class="announcement-bar__marquee">
    <div class="announcement-bar__track">
      {%- assign messages = section.settings.text | split: '|' -%}
      {%- comment -%} Repeat twice for seamless loop {%- endcomment -%}
      {%- for i in (1..2) -%}
        {%- for message in messages -%}
          <span class="announcement-bar__item">
            <span class="announcement-bar__sep">✦</span>
            {%- if section.settings.link != blank -%}
              <a href="{{ section.settings.link }}">{{ message | strip }}</a>
            {%- else -%}
              <span>{{ message | strip }}</span>
            {%- endif -%}
          </span>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "textarea",
      "id": "text",
      "default": "Free Worldwide Shipping on Orders Over $500 | Certified Authentic Timepieces | Swiss Precision Craftsmanship | Lifetime Servicing Guarantee | Complimentary Gift Packaging",
      "label": "Messages (separate with |)"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ]
}
{% endschema %}
