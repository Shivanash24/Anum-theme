<style>
  .craftsmanship-steps {
    padding: 8rem 0;
    background-color: var(--color-background);
  }

  .craftsmanship__header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .craftsmanship__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
    display: block;
  }

  .craftsmanship__title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: 0.1em;
    color: var(--color-foreground);
    margin: 0;
  }

  .craftsmanship__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media screen and (min-width: 768px) {
    .craftsmanship__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 4rem;
    }
  }

  @media screen and (min-width: 990px) {
    .craftsmanship__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
    }
  }

  .craftsmanship__step {
    position: relative;
    padding-left: 1.5rem;
    border-left: 1px solid rgba(0, 0, 0, 0.1);
  }

  .craftsmanship__step::before {
    content: '';
    position: absolute;
    left: -1px;
    top: 0;
    width: 2px;
    height: 0;
    background-color: var(--color-accent);
    transition: height 0.6s ease;
  }

  .craftsmanship__step:hover::before {
    height: 100%;
  }

  .craftsmanship__number {
    font-family: var(--font-heading-family);
    font-size: 3rem;
    line-height: 1;
    color: var(--color-accent);
    opacity: 0.3;
    margin-bottom: 1rem;
    display: block;
    transition: opacity 0.3s ease;
  }

  .craftsmanship__step:hover .craftsmanship__number {
    opacity: 1;
  }

  .craftsmanship__step-title {
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    color: var(--color-foreground);
  }

  .craftsmanship__step-text {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-foreground);
    opacity: 0.75;
    margin: 0;
  }
</style>

<section class="craftsmanship-steps">
  <div class="page-width">
    <div class="craftsmanship__header reveal">
      <span class="craftsmanship__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="craftsmanship__title">{{ section.settings.title }}</h2>
    </div>

    <div class="craftsmanship__grid">
      {%- for block in section.blocks -%}
        <div class="craftsmanship__step reveal reveal-delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
          <span class="craftsmanship__number">0{{ forloop.index }}</span>
          <h3 class="craftsmanship__step-title">{{ block.settings.title }}</h3>
          <p class="craftsmanship__step-text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Craftsmanship Steps",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Process"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Why Choose Aurum"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Precision Design"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Every timepiece begins as a vision, meticulously sketched and engineered to perfection."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Craftsmanship Steps",
      "blocks": [
        { "type": "step", "settings": { "title": "Vision & Design", "text": "Every timepiece begins as a vision, meticulously sketched and engineered to perfection." } },
        { "type": "step", "settings": { "title": "Material Selection", "text": "We source only the finest materials, from conflict-free diamonds to aerospace-grade titanium." } },
        { "type": "step", "settings": { "title": "Master Assembly", "text": "Our master horologists assemble hundreds of microscopic components by hand." } },
        { "type": "step", "settings": { "title": "Rigorous Testing", "text": "Each watch undergoes 500 hours of testing to ensure flawless performance under any condition." } }
      ]
    }
  ]
}
{% endschema %}
