<style>
  .cta-banner-section {
    position: relative;
    overflow: hidden;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-foreground);
  }

  .cta-banner__bg-image {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .cta-banner__bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.05);
    transition: transform 8s ease;
  }

  .cta-banner-section:hover .cta-banner__bg-image img {
    transform: scale(1.0);
  }

  .cta-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      135deg,
      rgba(0,0,0,0.75) 0%,
      rgba(0,0,0,0.45) 100%
    );
    overflow: hidden;
  }

  .cta-banner__shimmer {
    position: absolute;
    top: 0;
    left: -150%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      to right,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.05) 50%,
      rgba(255, 255, 255, 0) 100%
    );
    transform: skewX(-20deg);
    animation: shimmer 8s infinite cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  @keyframes shimmer {
    0% { left: -150%; }
    50% { left: 150%; }
    100% { left: 150%; }
  }

  .cta-banner__content {
    position: relative;
    z-index: 3;
    text-align: center;
    padding: 6rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .cta-banner__eyebrow {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .cta-banner__title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 200;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ffffff;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .cta-banner__subtitle {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.8);
    letter-spacing: 0.05em;
    line-height: 1.7;
    margin-bottom: 3rem;
    font-weight: 300;
  }

  .cta-banner__buttons {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-banner__btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.1rem 3rem;
    background-color: var(--color-accent);
    color: var(--color-background);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px solid var(--color-accent);
    transition: all 0.35s ease;
  }

  .cta-banner__btn-primary:hover {
    background-color: transparent;
    color: var(--color-accent);
  }

  .cta-banner__btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.1rem 3rem;
    background-color: transparent;
    color: #ffffff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.85rem;
    font-weight: 500;
    border: 1px solid rgba(255,255,255,0.6);
    transition: all 0.35s ease;
  }

  .cta-banner__btn-secondary:hover {
    background-color: #ffffff;
    color: #000000;
    border-color: #ffffff;
  }
</style>

<section class="cta-banner-section">
  <div class="cta-banner__bg-image">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy" loading="lazy">
    {%- else -%}
      <img src="{{ 'luxury_watch_hero.jpg' | asset_url }}" alt="Luxury Watch" loading="lazy" loading="lazy">
    {%- endif -%}
  </div>

  <div class="cta-banner__overlay">
    <div class="cta-banner__shimmer"></div>
  </div>

  <div class="cta-banner__content reveal">
    {%- if section.settings.eyebrow != blank -%}
      <span class="cta-banner__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <h2 class="cta-banner__title">{{ section.settings.title }}</h2>

    {%- if section.settings.subtitle != blank -%}
      <p class="cta-banner__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    <div class="cta-banner__buttons">
      {%- if section.settings.btn_primary_label != blank -%}
        <a href="{{ section.settings.btn_primary_link | default: '#' }}" class="cta-banner__btn-primary">
          {{ section.settings.btn_primary_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.btn_secondary_label != blank -%}
        <a href="{{ section.settings.btn_secondary_link | default: '#' }}" class="cta-banner__btn-secondary">
          {{ section.settings.btn_secondary_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Limited Edition"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Discover the New Prestige Collection"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "A rare selection of timepieces crafted for those who demand nothing less than perfection."
    },
    {
      "type": "text",
      "id": "btn_primary_label",
      "label": "Primary Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn_primary_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "btn_secondary_label",
      "label": "Secondary Button Label",
      "default": "View Lookbook"
    },
    {
      "type": "url",
      "id": "btn_secondary_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ]
}
{% endschema %}
