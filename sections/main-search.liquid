<div class="search-page page-width">
  <div class="search-page__header center">
    <h1>Search Results</h1>
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
      <div class="field">
        <input class="search-form__input field__input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search our store">
        <button type="submit" class="search-form__button" aria-label="Search">
          {% render 'icon-search' %}
        </button>
      </div>
    </form>
  </div>

  {%- if search.performed -%}
    {%- paginate search.results by 12 -%}
      <div class="search-page__results">
        {%- if search.results_count == 0 -%}
          <p class="center">No results found for "{{ search.terms | escape }}".</p>
        {%- else -%}
          <p class="center">Showing {{ search.results_count }} results for "{{ search.terms | escape }}"</p>
          <ul class="grid grid--3-col">
            {%- for item in search.results -%}
              <li class="grid__item">
                {%- if item.object_type == 'product' -%}
                  {% render 'product-card', product: item %}
                {%- elsif item.object_type == 'article' -%}
                  <div class="article-card">
                    <h3><a href="{{ item.url }}">{{ item.title }}</a></h3>
                    <p>{{ item.excerpt_or_content | strip_html | truncatewords: 30 }}</p>
                  </div>
                {%- elsif item.object_type == 'page' -%}
                  <div class="page-card">
                    <h3><a href="{{ item.url }}">{{ item.title }}</a></h3>
                  </div>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
          {% render 'pagination', paginate: paginate %}
        {%- endif -%}
      </div>
    {%- endpaginate -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search Results",
  "settings": []
}
{% endschema %}
