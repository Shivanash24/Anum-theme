<div class="customer activate page-width center">
  <div class="customer__inner">
    <h1>Activate account</h1>
    <p>Create your password to activate your account.</p>
    {%- form 'activate_customer_password' -%}
      {%- if form.errors -%}
        <div class="form__message" tabindex="-1" autofocus>
          <ul>
            {%- for field in form.errors -%}
              <li>
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  <a href="#{{ field }}">{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="field">
        <input type="password" name="customer[password]" id="password" autocomplete="new-password" placeholder="Password" required>
      </div>
      <div class="field">
        <input type="password" name="customer[password_confirmation]" id="password_confirmation" autocomplete="new-password" placeholder="Confirm password" required>
      </div>

      <button class="button">Activate account</button>
      <button class="button button--secondary" name="decline">Decline invitation</button>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Activate Account",
  "settings": []
}
{% endschema %}
