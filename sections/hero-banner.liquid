<style>
  .hero-banner {
    position: relative;
    width: 95%;
    max-width: 1600px;
    margin: 2rem auto;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: var(--shadow-luxury);
  }
  
  .hero-banner--fullscreen { height: 85vh; }
  .hero-banner--large { height: 70vh; }
  .hero-banner--medium { height: 50vh; }
  .hero-banner--small { height: 35vh; }

  .hero-banner__image-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hero-banner__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  /* Premium Dark Gradient Overlay */
  .hero-banner::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.3) 100%);
    z-index: 2;
    pointer-events: none;
  }

  .hero-banner__content-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: center; /* Will be overridden by inline align-items if needed, but justify-content aligns vertically here if flex-direction is column */
    padding: 2rem;
  }

  .hero-banner__content {
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
    color: #ffffff;
  }

  .hero-banner__heading {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 300;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    line-height: 1.2;
    color: #ffffff;
    text-shadow: 0 4px 15px rgba(0,0,0,0.4);
  }

  .hero-banner__text {
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 300;
    letter-spacing: 0.05em;
    margin-bottom: 3rem;
    line-height: 1.6;
    color: #ffffff;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
    opacity: 0.9;
  }

  .hero-banner .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.2rem 3.5rem;
    background-color: transparent;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.85rem;
    font-weight: 500;
    border: 1px solid #ffffff;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .hero-banner .button:hover {
    background-color: var(--color-accent);
    color: var(--color-button-text);
    border-color: var(--color-accent);
  }
</style>

<div class="hero-banner hero-banner--{{ section.settings.height }}">
  <div class="hero-banner__image-wrapper">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2000 }}"
           alt="{{ section.settings.image.alt | escape }}"
           width="2000"
           height="{{ 2000 | divided_by: section.settings.image.aspect_ratio | ceil }}"
           loading="eager"
           fetchpriority="high"
           class="hero-banner__image">
    {%- else -%}
      <img src="{{ 'landscape_premium_watch.jpg' | asset_url }}"
           alt="Premium Luxury Watch"
           width="2000"
           height="1000"
           loading="eager"
           fetchpriority="high"
           class="hero-banner__image"
           style="width: 100%; height: 100%; object-fit: cover;">
    {%- endif -%}
  </div>

  <div class="hero-banner__content-wrapper" style="align-items: {{ section.settings.alignment }};">
    <div class="hero-banner__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h1 class="hero-banner__heading reveal reveal-delay-1" {{ block.shopify_attributes }}>
              {{ block.settings.heading | escape }}
            </h1>
          {%- when 'text' -%}
            <p class="hero-banner__text reveal reveal-delay-2" {{ block.shopify_attributes }}>
              {{ block.settings.text | escape }}
            </p>
          {%- when 'buttons' -%}
          <div class="hero__buttons buttons-group" {{ block.shopify_attributes }}>
            {%- if block.settings.button_label_1 != blank -%}
              <a href="{{ block.settings.button_link_1 }}" class="button button--primary">{{ block.settings.button_label_1 }}</a>
            {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Banner Height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "fullscreen", "label": "Fullscreen" }
      ],
      "default": "fullscreen"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "default": "The Timeless Collection", "label": "Heading" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "default": "Discover the art of precision and elegance.", "label": "Text" }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "button_label_1", "default": "Shop now", "label": "Button label" },
        { "type": "url", "id": "button_link_1", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}
