        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author Title",
          "default": "Collector, London"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
