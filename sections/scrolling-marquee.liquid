<div class="scrolling-marquee" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; padding: {{ section.settings.padding_y }}px 0;">
  <div class="scrolling-marquee__track">
    {%- for i in (1..3) -%}
      <div class="scrolling-marquee__content" aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}">
        {%- for block in section.blocks -%}
          <span class="scrolling-marquee__item">{{ block.settings.text }}</span>
          {%- unless forloop.last -%}
            <span class="scrolling-marquee__separator">•</span>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>
</div>

<style>
.scrolling-marquee {
  overflow: hidden;
  white-space: nowrap;
  display: flex;
  align-items: center;
  position: relative;
  z-index: 10;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}

.scrolling-marquee__track {
  display: flex;
  animation: marquee {{ section.settings.speed }}s linear infinite;
}

.scrolling-marquee__content {
  display: flex;
  flex-shrink: 0;
  padding-right: 30px;
}

.scrolling-marquee__item {
  font-family: var(--font-heading-family);
  font-size: {{ section.settings.font_size }}px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  padding: 0 30px;
}

.scrolling-marquee__separator {
  opacity: 0.5;
}

@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-100%); }
}

@media (max-width: 768px) {
  .scrolling-marquee__item {
    font-size: {{ section.settings.font_size | divided_by: 1.5 }}px;
  }
}
</style>

{% schema %}
{
  "name": "Scrolling Marquee",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#D4AF37"
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 10,
      "max": 60,
      "step": 5,
      "label": "Vertical Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 50,
      "step": 5,
      "label": "Scroll Speed (seconds)",
      "default": 20
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 16,
      "max": 64,
      "step": 2,
      "label": "Font Size",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Luxury Heritage"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling Marquee",
      "blocks": [
        { "type": "text", "settings": { "text": "Uncompromising Quality" } },
        { "type": "text", "settings": { "text": "Swiss Craftsmanship" } },
        { "type": "text", "settings": { "text": "Timeless Elegance" } }
      ]
    }
  ]
}
{% endschema %}
