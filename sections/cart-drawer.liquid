<div class="cart-drawer drawer" id="CartDrawer" role="dialog" aria-modal="true" aria-label="Your cart">
  <div class="drawer__inner">
    <div class="drawer__header">
      <h2 class="drawer__heading">Your cart</h2>
      <button class="drawer__close" type="button" aria-label="Close">
        {% render 'icon-close' %}
      </button>
    </div>
    <cart-drawer-items class="drawer__contents">
      {%- if cart == empty -%}
        <div class="drawer__empty">
          <p>Your cart is currently empty.</p>
          <a href="{{ routes.all_products_collection_url }}" class="button">Continue shopping</a>
        </div>
      {%- else -%}
        <form action="{{ routes.cart_url }}" id="CartDrawer-Form" class="cart__contents" method="post">
          <div class="drawer__items">
            {%- for item in cart.items -%}
              <div class="cart-item">
                <!-- Cart item details similar to main-cart-items -->
                <div class="cart-item__media">
                   {% if item.image %}
                    <img src="{{ item.image | image_url: width: 100 }}" alt="{{ item.image.alt | escape }}" loading="lazy" width="100" height="{{ 100 | divided_by: item.image.aspect_ratio | ceil }}" loading="lazy">
                  {% endif %}
                </div>
                <div class="cart-item__details">
                  <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title | escape }}</a>
                  <div class="cart-item__price">{{ item.final_line_price | money }}</div>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </form>
      {%- endif -%}
    </cart-drawer-items>
    {%- if cart != empty -%}
      <div class="drawer__footer">
        <div class="drawer__subtotal">
          <p>Subtotal</p>
          <p>{{ cart.total_price | money_with_currency }}</p>
        </div>
        <button type="submit" id="CartDrawer-Checkout" class="button button--primary" name="checkout" form="CartDrawer-Form">
          Checkout
        </button>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
