{%- liquid
  assign target = product.selected_or_first_available_variant
  assign compare_at_price = target.compare_at_price
  assign price = target.price
  assign unit_price = target.unit_price
  assign unit_price_measurement = target.unit_price_measurement
-%}
<div class="price{% if compare_at_price > price %} price--on-sale{% endif %}">
  <div class="price__container">
    {%- if compare_at_price > price -%}
      <span class="visually-hidden">Regular price</span>
      <s class="price__regular">{{ compare_at_price | money }}</s>
      <span class="visually-hidden">Sale price</span>
      <span class="price__sale">{{ price | money }}</span>
    {%- else -%}
      <span class="visually-hidden">Regular price</span>
      <span class="price__regular">{{ price | money }}</span>
    {%- endif -%}
  </div>

  {%- if unit_price_measurement -%}
    <div class="unit-price">
      <span class="visually-hidden">Unit price</span>
      <span>{{ unit_price | money }}</span>
      <span aria-hidden="true">/</span>
      <span class="visually-hidden">&nbsp;per&nbsp;</span>
      <span>
        {%- if unit_price_measurement.reference_value != 1 -%}
          {{- unit_price_measurement.reference_value -}}
        {%- endif -%}
        {{ unit_price_measurement.reference_unit }}
      </span>
    </div>
  {%- endif -%}
</div>

